{
    "mcpServers": {
        "context7": {
            "type": "http",
            "url": "https://mcp.context7.com/mcp"
        },
        "nuxt-remote": {
            "type": "http",
            "url": "https://nuxt.com/mcp"
        },
        "playwright": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@playwright/mcp@latest"
            ]
        },
        "chrome-devtools": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "chrome-devtools-mcp@latest",
                "--browser-url=http://127.0.0.1:9222"
            ]
        }
    }
}